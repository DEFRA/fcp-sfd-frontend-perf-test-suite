              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import org.apache.jmeter.protocol.http.control.*

//Get cookie manager
CookieManager cm = sampler.getCookieManager()

Cookie c = cm.get(0)
log.info(&quot;******************** Cookies #1: &quot; + c.getName() + &quot;cookie Value: &quot; + c.getValue())

//put crumb cookie value into variable called &quot;crumb&quot;
vars.put(&quot;crumb&quot;,c.getValue());
</stringProp>
